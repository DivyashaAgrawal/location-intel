# Copy to .env and fill in. .env is gitignored; this file is not.

# Primary maps source. Required for production-quality output; the app
# falls through to Serper / OSM / mock when absent.
GOOGLE_PLACES_API_KEY=

# Fallback when Google Places returns empty for a city.
SERPER_API_KEY=

# Optional hot cache. Absent/unreachable -> cache_manager degrades to SQLite.
REDIS_URL=redis://localhost:6379/0

# Local NLU via Ollama. Unreachable -> rule-based fallback parser.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# Structured-logging level. One of DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# Override persistent DB path (defaults to location_intel/src.db).
# LOCATION_INTEL_DB_PATH=/absolute/path/to/src.db
